class "xen" {
    match if substring(hardware,1,3) = 00:16:3e;
}

class "virtualbox" {
    match if substring(hardware,1,3) = 08:00:27;
}

#
#  Internal (private) subnet (Migrating 192.168.10/24 to 192.168.8/24 via /22)
#
subnet 192.168.8.0 netmask 255.255.252.0 {
    authoritative;
    option routers			192.168.8.1;			# Routers
    option broadcast-address		192.168.11.255;
    option ntp-servers			downbelow,cyteen,panparis;	# RFC 1035 (v3)
    option log-servers			downbelow,resune,panparis;
    option lpr-servers			downbelow,resune,panparis;
    option domain-name-servers		downbelow,resune,cyteen;	# DNS Servers
    option domain-name			"home.ka8zrt.com";		# DNS Domain
    option domain-search		"home.ka8zrt.com", "dmz.ka8zrt.com", "ka8zrt.com";

    option timezone			"US/Eastern";

    pool {
	allow unknown clients;
	deny members of "access-point";

	range dynamic-bootp		192.168.8.129 192.168.8.159;
	range				192.168.8.160 192.168.8.191;

	min-lease-time			600;			# 10 min
	default-lease-time		3600;			#  1 hour
	max-lease-time			3600;			#  1 hour
    }
}

#
#  VLAN 11 - DEV (Disabled for migration)
