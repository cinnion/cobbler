## # $dhcp_tag
## # $mac
## # $iface
## # $cid
## # $_v
##
host $dhcp_tag {
    hardware ethernet			$mac;
#if $cid and $cid[0:7] != 'generic'
    option dhcp-client-identifier	"$cid";
#end if
#if $iface.dns_name and $iface.dns_name[0:7] != 'generic'
    option host-name			"$iface.dns_name";
#else if $iface.hostname and $iface.hostname[0:7] != 'generic'
    option host-name			"$iface.hostname";
#else if $iface.name and $iface.name[0:7] != 'generic'
    option host-name			"$iface.name";
#end if

#if $iface.ip_address and $iface.ip_address[0:7] != 'generic'
    fixed-address			$iface.ip_address;
#else if $iface.dns_name and $iface.dns_name[0:7] != 'generic'
    fixed-address			$iface.dns_name;
#else if $iface.hostname and $iface.hostname[0:7] != 'generic'
    fixed-address			$iface.hostname;
#else if $iface.name and $iface.name[0:7] != 'generic'
    fixed-address			$iface.name;
#else
    fixed-address			$dhcp_tag;
#end if
#if $iface.netmask
    option subnet-mask			$iface.netmask;
#end if
#if $iface.gateway
    option routers			$iface.gateway;
#end if
#if $iface.netboot_enabled
    filename				"$iface.filename";
    ## Cobbler defaults to $next_server, but some users
    ## like to use $iface.system.server for proxied setups
#if $iface.next_server
    next-server				$iface.next_server;
#else
    next-server				$next_server;
#end if
    ## next-server $iface.system.server;
#end if
}
#end for
#end for

